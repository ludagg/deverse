# DEVERSE — GitHub OAuth configuration.
# Copy this file to `.env` (gitignored) and fill in the values from a GitHub
# OAuth App: https://github.com/settings/developers → "New OAuth App".
#
# Authorization callback URL must match the app origin, e.g.
#   http://localhost:5173/        (local dev)
#   https://<your-app>.vercel.app/ (production)

# Public — shipped to the browser. When set, "Sign in with GitHub" uses the real
# OAuth redirect. When empty, the app falls back to fetching a public profile by
# username (no backend, 60 req/h per IP).
VITE_GITHUB_CLIENT_ID=

# Server-only — used by the serverless function (api/github-callback.js) to
# exchange the OAuth code for a token. NEVER expose this to the browser.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Database (Postgres: Supabase / Neon / Vercel Postgres). Server-only.
# Use the POOLED connection string in serverless (Supabase → "Transaction"
# pooler). When empty, the API returns no rows and the app falls back to the
# bundled fiction dataset. Set the same value in Vercel's env vars.
DATABASE_URL=

# Read-only GitHub Personal Access Token, used ONLY by `npm run seed` to fetch
# real developers into the database. Not needed at runtime. Classic token with
# public access (no scopes) is enough.
GITHUB_TOKEN=
